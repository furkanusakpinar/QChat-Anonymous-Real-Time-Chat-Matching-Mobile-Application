# Firebase Configuration
# Copy this file to .env and fill in your own Firebase project credentials.
# You can also configure Firebase from inside the app via Settings > Firebase Setup.

FIREBASE_API_KEY=your_api_key_here
FIREBASE_AUTH_DOMAIN=your_project.firebaseapp.com
FIREBASE_DATABASE_URL=https://your_project-default-rtdb.firebaseio.com
FIREBASE_PROJECT_ID=your_project_id
FIREBASE_STORAGE_BUCKET=your_project.firebasestorage.app
FIREBASE_MESSAGING_SENDER_ID=your_sender_id
FIREBASE_APP_ID=1:your_app_id:web:your_web_hash
FIREBASE_MEASUREMENT_ID=G-YOUR_MEASUREMENT_ID
